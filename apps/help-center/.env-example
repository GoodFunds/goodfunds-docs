# OpenAI (ChatGPT) — powers the Help Center AI chat assistant.
# Create a key at https://platform.openai.com/api-keys
OPENAI_API_KEY=sk-...

# Optional overrides (sensible defaults are used when unset):
# OPENAI_MODEL=gpt-4o-mini                 # chat completion model
# OPENAI_EMBED_MODEL=text-embedding-3-small # semantic-retrieval embeddings
# OPENAI_BASE_URL=                          # proxy / Azure-compatible gateway
# OPENAI_EMBED_BATCH=256                    # inputs per embeddings request
# CHAT_SEM_THRESHOLD=0.3                    # cosine floor for "relevant" (analytics)
# CHAT_ANALYTICS_FILE=.data/chat-events.jsonl 
