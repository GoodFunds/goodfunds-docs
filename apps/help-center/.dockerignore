# Dependencies & build output (reinstalled / regenerated inside the image)
node_modules
.next
.source
out
build
*.tsbuildinfo

# Local runtime data & secrets — never bake into the image
.data
.env*.local

# VCS / tooling / editor
.git
.gitignore
.vscode
.idea

# Docker files themselves
Dockerfile
.dockerignore

# Docs & one-off scripts not needed in the runtime image
*.md
scripts

# Logs
npm-debug.log*
yarn-debug.log*
yarn-error.log*
